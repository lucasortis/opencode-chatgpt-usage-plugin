{
  "name": "@lucasortis/opencode-chatgpt-usage-plugin",
  "version": "0.0.4",
  "description": "OpenCode TUI plugin that shows ChatGPT usage limits.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "exports": {
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.jsx"
    }
  },
  "types": "./dist/tui.d.ts",
  "scripts": {
    "build": "npm run clean && npm run build:runtime && npm run build:types",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run test && npm run build",
    "pretest": "npm run build",
    "release:update-opencode": "bash ./scripts/release-and-update-opencode.sh",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lucasortis/opencode-chatgpt-usage-plugin.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@opentui/solid": "^0.1.102"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@opencode-ai/plugin": "^1.14.19",
    "@opentui/core": "^0.1.102",
    "@opentui/solid": "^0.1.102",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "glob": "13.0.6",
    "diff": "9.0.0",
    "jimp": "1.6.1"
  },
  "engines": {
    "opencode": "^1.0.0"
  }
}
